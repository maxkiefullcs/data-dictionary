# PostgreSQL – copy to .env (Docker) or .env.local (local dev) and set real values.
# For Docker: use env_file: .env in docker-compose; do not hardcode credentials.
# Use your internal DB host (e.g. 192.168.0.213) so the container can reach it on the same network.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@192.168.0.213:5432/imed_bhh

# Optional: UI can connect to another DB name via free text (Connect button).
# It reuses host/user/password from DATABASE_URL and only switches database name.

# Optional: operation logs (server-side). Default: ./logs/app.log
# LOG_DIR=./logs
# LOG_LEVEL=info
